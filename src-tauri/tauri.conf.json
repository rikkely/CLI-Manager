{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CLI-Manager",
  "version": "0.1.8",
  "identifier": "com.cli-manager.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CLI-Manager",
        "decorations": false,
        "center": true,
        "width": 1200,
        "height": 800,
        "minWidth": 350,
        "minHeight": 600,
        "backgroundColor": "#1a1b26"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["$APPLOCALDATA/backgrounds/**"],
          "deny": []
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }}
